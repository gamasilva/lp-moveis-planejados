---
import { Image } from 'astro:assets';
---
<footer class="w-full py-20 bg-black border-t border-neutral-900 border-b-8 border-b-[#C5A03F] flex flex-col items-center">
  <div class="max-w-7xl mx-auto px-4 flex flex-col w-full">
    <div class="flex flex-col md:flex-row gap-12 justify-between mb-16 w-full">
      <div class="flex flex-col w-full md:max-w-sm">
        <h2 class="text-[#C5A03F] text-2xl font-heading font-bold mb-4 tracking-tight">Modular Montagens Pensadas</h2>
        <p class="text-neutral-400 text-lg mb-8">
          Elevando o padrão de montagem e mobiliário em Cuiabá. Design exclusivo, execução cirúrgica e atendimento prime da nossa equipe.
        </p>
        
        <div class="flex items-center gap-4 w-full">
          <a href="#" aria-label="Instagram" class="w-12 h-12 rounded-xl bg-neutral-900 flex items-center justify-center text-neutral-400 hover:text-[#C5A03F] hover:bg-neutral-800 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
        </div>
      </div>
      
      <div class="flex flex-col w-full md:max-w-xs">
        <p class="text-white font-bold tracking-tight mb-6 uppercase text-sm">Contato</p>
        <div class="flex flex-col gap-4 text-neutral-400 text-lg">
          <p>Cuiabá - MT</p>
          <p>Telefone: 65 8477-2460</p>
        </div>
      </div>

      <div class="flex flex-col w-full md:max-w-xs">
        <p class="text-white font-bold tracking-tight mb-6 uppercase text-sm">Links Úteis</p>
        <ul class="flex flex-col gap-4 w-full">
          <li><a href="#projetos" class="text-neutral-400 text-lg hover:text-[#C5A03F] transition-colors flex items-center">Projetos Exclusivos</a></li>
          <li><a href="#depoimentos" class="text-neutral-400 text-lg hover:text-[#C5A03F] transition-colors flex items-center">Depoimentos</a></li>
        </ul>
      </div>
    </div>
    
    <div class="w-full pt-8 border-t border-neutral-900 flex flex-col md:flex-row items-center justify-between text-neutral-500 text-lg gap-6 text-center md:text-left">
      <div class="flex flex-col gap-2">
        <p>&copy; {new Date().getFullYear()} Modular Montagens Pensadas. Todos os direitos reservados.</p>
        <p class="text-sm text-neutral-600">Desenvolvido por <a href="https://www.autosocialflow.com.br/" target="_blank" rel="noopener noreferrer" class="text-[#C5A03F] hover:text-white transition-colors">Auto Social Flow</a></p>
      </div>
      <div class="flex flex-row items-center gap-6">
        <a href="#" class="hover:text-[#C5A03F] transition-colors">Privacidade</a>
        <a href="#" class="hover:text-[#C5A03F] transition-colors">Termos de Uso</a>
      </div>
    </div>
  </div>
</footer>
