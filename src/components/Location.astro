---
---
<section class="w-full py-24 bg-black border-t border-neutral-900" id="localizacao">
  <div class="max-w-7xl mx-auto px-4 flex flex-col w-full">
    
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center w-full">
      
      <!-- Left Column: Location Info Card -->
      <div class="flex flex-col w-full">
        <div class="inline-flex items-center gap-3 mb-6">
          <span class="h-px w-8 bg-[#C5A03F]"></span>
          <span class="text-[#C5A03F] uppercase tracking-widest text-xs font-bold">Localização</span>
        </div>
        <h2 class="font-heading text-4xl sm:text-5xl text-white font-bold tracking-tight mb-6">Visite a nossa oficina</h2>
        <p class="text-neutral-400 text-lg mb-8 leading-relaxed">
          Venha acompanhar de perto a precisão do nosso plano de corte computadorizado e conferir a qualidade dos acabamentos e ferragens que utilizamos em nossos móveis sob medida.
        </p>

        <!-- Location Details Cards -->
        <div class="flex flex-col gap-6 mb-8">
          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-center text-[#C5A03F] flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-white font-bold text-base">Endereço</span>
              <p class="text-neutral-400 text-sm mt-1">Cuiabá - MT</p>
              <span class="text-neutral-500 text-xs mt-1">Atendimento presencial com agendamento prévio para total exclusividade.</span>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-10 h-10 rounded-lg bg-neutral-900 border border-neutral-800 flex items-center justify-center text-[#C5A03F] flex-shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div class="flex flex-col">
              <span class="text-white font-bold text-base">Horário de Funcionamento</span>
              <p class="text-neutral-400 text-sm mt-1">Segunda a Sexta: 08h às 18h</p>
              <p class="text-neutral-400 text-sm">Sábado: 08h às 12h</p>
            </div>
          </div>
        </div>

        <a 
          href="https://www.google.com/maps/search/?api=1&query=-15.653021406042594,-56.09932150861228" 
          target="_blank" 
          rel="noopener noreferrer"
          class="bg-neutral-900 border border-neutral-800 text-white rounded-full px-8 py-4 flex items-center justify-center font-semibold text-sm gap-2 hover:bg-[#C5A03F] hover:text-black hover:border-transparent transition-all duration-300 w-full sm:w-auto cursor-pointer focus-visible:ring-2 focus-visible:ring-[#C5A03F] min-h-[44px]"
          aria-label="Abrir rota para a oficina no Google Maps"
        >
          <span>Traçar Rota no Google Maps</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L16 4m0 13V4m0 0L9 7" />
          </svg>
        </a>
      </div>

      <!-- Right Column: Interactive Map Iframe -->
      <div class="w-full relative h-[350px] sm:h-[400px] lg:h-[450px] rounded-2xl overflow-hidden border border-neutral-800 shadow-[0_0_40px_rgba(0,0,0,0.4)] group">
        <!-- Accent outline hover effect -->
        <div class="absolute inset-0 border border-[#C5A03F]/0 group-hover:border-[#C5A03F]/20 rounded-2xl transition-all duration-500 pointer-events-none z-10"></div>
        <iframe 
          src="https://www.google.com/maps/embed?pb=!1m17!1m12!1m3!1d403.0200325242617!2d-56.09932150861228!3d-15.653021406042594!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m2!1m1!2s!5e1!3m2!1spt-BR!2sbr!4v1780441931269!5m2!1spt-BR!2sbr" 
          width="100%" 
          height="100%" 
          style="border:0;" 
          allowfullscreen="" 
          loading="lazy" 
          referrerpolicy="no-referrer-when-downgrade"
          class="w-full h-full grayscale invert opacity-80 contrast-[1.1] hover:grayscale-0 hover:invert-0 hover:opacity-100 transition-all duration-700"
          title="Mapa de localização da Modular Montagens Pensadas em Cuiabá"
        ></iframe>
      </div>

    </div>
  </div>
</section>
