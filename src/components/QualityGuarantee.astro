---
const attributes = [
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />`,
    title: 'Entrega Pontual Garantida.',
    desc: 'Seu projeto montado no prazo combinado. Respeitamos o seu tempo e o seu investimento.'
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />`,
    title: 'Montagem Limpa e Cuidadosa.',
    desc: 'Nossa especialidade está no nome. Execução silenciosa e com respeito absoluto ao seu piso e às suas paredes.'
  },
  {
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />`,
    title: 'Durabilidade Premium.',
    desc: 'Usamos apenas 100% MDF de alta densidade e ferragens com amortecimento. Feito para durar uma vida.'
  }
];
---
<section class="w-full py-24 bg-black border-t border-neutral-900 relative overflow-hidden" id="qualidade">
  <!-- Grid background decorativo -->
  <div class="absolute inset-0 z-0 bg-grid-tech"></div>
  <div class="absolute inset-0 bg-gradient-to-b from-black via-transparent to-black z-0 pointer-events-none"></div>

  <div class="max-w-7xl mx-auto px-4 flex flex-col items-center w-full relative z-10">
    <div class="text-center mb-16 flex flex-col items-center justify-center w-full">
      <h2 class="font-heading text-4xl sm:text-5xl text-white font-bold tracking-tight mb-4">Padrão de Qualidade</h2>
      <p class="text-neutral-400 text-lg max-w-2xl">Não fazemos concessões na estrutura. Cada componente fabricado é devidamente selecionado e auditado para suportar o teste das tendências temporais e do uso constante.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full">
      {attributes.map((attr) => (
        <div class="bg-neutral-900/60 backdrop-blur-md border border-neutral-800 rounded-xl p-8 flex flex-col hover:border-[#C5A03F]/50 hover:-translate-y-1 transition-all duration-300 group shadow-lg">
          <div class="w-14 h-14 bg-black border border-neutral-800 rounded-xl flex items-center justify-center mb-6 group-hover:bg-[#C5A03F]/10 group-hover:border-[#C5A03F]/50 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-[#C5A03F]" fill="none" viewBox="0 0 24 24" stroke="currentColor" set:html={attr.icon} />
          </div>
          <h3 class="text-white text-xl font-bold font-heading tracking-tight mb-3">{attr.title}</h3>
          <p class="text-neutral-400 text-lg leading-relaxed">{attr.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
