          </div>
        ))}
      </div>

      <!-- Navigation Arrows (Desktop) -->
      <div class="hidden md:flex justify-center items-center gap-4 mt-8">
        <button
          id="prev-btn"
          class="w-12 h-12 rounded-full border border-neutral-800 bg-neutral-950 hover:bg-neutral-900 hover:border-[#C5A03F]/40 flex items-center justify-center text-white transition-all cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-[#C5A03F] min-h-[44px] min-w-[44px]"
          aria-label="Avaliação anterior"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 19l-7-7 7-7" />
          </svg>
        </button>
        <button
          id="next-btn"
          class="w-12 h-12 rounded-full border border-neutral-800 bg-neutral-950 hover:bg-neutral-900 hover:border-[#C5A03F]/40 flex items-center justify-center text-white transition-all cursor-pointer focus:outline-none focus-visible:ring-2 focus-visible:ring-[#C5A03F] min-h-[44px] min-w-[44px]"
          aria-label="Próxima avaliação"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
          </svg>
        </button>
      </div>

      <!-- Pagination Dots (Mobile) -->
      <div class="flex md:hidden justify-center items-center gap-2 mt-6" id="carousel-dots">
        {testimonials.map((_, index) => (
          <button
            class="w-2.5 h-2.5 rounded-full bg-neutral-800 transition-all duration-300 focus:outline-none focus-visible:ring-2 focus-visible:ring-[#C5A03F] min-h-[12px] min-w-[12px]"
            data-index={index}
            aria-label={`Ir para avaliação ${index + 1}`}
          ></button>
        ))}
      </div>

    </div>
    
  </div>
</section>

<!-- Scoped Styles to hide scrollbar -->
<style>
  #carousel-track::-webkit-scrollbar {
    display: none;
  }
  #carousel-track {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>

<!-- Carousel Script -->
<script>
  const track = document.getElementById('carousel-track');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dots = document.querySelectorAll('#carousel-dots button');

  if (track) {
    const getScrollStep = () => {
      const firstSlide = track.querySelector('div');
      return firstSlide ? firstSlide.offsetWidth + 24 : 320; // slide width + gap
    };

    if (prevBtn && nextBtn) {
      prevBtn.addEventListener('click', () => {
        track.scrollBy({ left: -getScrollStep(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', () => {
        track.scrollBy({ left: getScrollStep(), behavior: 'smooth' });
      });
    }

    const updateActiveDot = () => {
      const scrollPosition = track.scrollLeft;
      const slideWidth = getScrollStep();
      const activeIndex = Math.round(scrollPosition / slideWidth);
      
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.remove('bg-neutral-800');
          dot.classList.add('bg-[#C5A03F]', 'w-5');
        } else {
          dot.classList.remove('bg-[#C5A03F]', 'w-5');
          dot.classList.add('bg-neutral-800');
        }
      });
    };

    // Track scroll events
    track.addEventListener('scroll', updateActiveDot);
    
    // Initialize active dot status
    updateActiveDot();

    // Dot navigation click handlers
    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt(dot.getAttribute('data-index') || '0', 10);
        const slideWidth = getScrollStep();
        track.scrollTo({ left: index * slideWidth, behavior: 'smooth' });
      });
    });
  }
</script>

