        <!-- Glow effect -->
        <div class="absolute -inset-px bg-gradient-to-r from-[#C5A03F]/10 to-transparent rounded-2xl opacity-50 pointer-events-none"></div>
        
        <div class="text-center sm:text-left">
          <div class="flex items-center justify-center sm:justify-start gap-2">
            <span class="text-white text-5xl font-heading font-black leading-none">5.0</span>
