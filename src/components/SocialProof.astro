---
const testimonials = [
  { name: 'Ricardo Mendes', time: 'Há 2 semanas', text: 'A exatidão na entrega e o rigor milimétrico do MDF superaram todas as minhas expectativas como cliente extremamente exigente. O home theater e o closet do casal ficaram intocáveis e a montagem foi a mais impecável que já vi.', rating: 5, initial: 'R' },
  { name: 'Fernanda Albuquerque', time: 'Há 1 mês', text: 'A atenção aos detalhes estruturais e a montagem limpa garantem a excelência dos meus projetos. A equipe executou minha linha de design exatamente como desenhado na tela, preservando o valor investido.', rating: 5, initial: 'F' },
  { name: 'João Carlos Fonseca', time: 'Há 3 meses', text: 'Ferragens silenciosas impecáveis europeias e um capricho que você nota na primeira vez que abre as portas. Transformaram inteiramente a dinâmica visual e o impacto arquitetônico da nossa cobertura.', rating: 5, initial: 'J' },
];
---
<section class="w-full py-24 bg-neutral-950 border-t border-neutral-900" id="depoimentos">
  <div class="max-w-7xl mx-auto px-4 flex flex-col items-center w-full">
    
    <div class="text-center mb-16 flex flex-col items-center justify-center w-full">
      <div class="flex items-center gap-2 px-4 py-2 bg-neutral-900 border border-neutral-800 rounded-full mb-6">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 488 512" class="w-5 h-5 fill-white"><path d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 123 24.5 166.3 64.9l-67.5 64.9C258.5 52.6 94.3 116.6 94.3 256c0 86.5 69.1 156.6 153.7 156.6 98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 24.9 3.9 41.4z"/></svg>
        <span class="text-white text-sm font-bold tracking-tight">Avaliações 5.0 no Google</span>
      </div>
      <h2 class="font-heading text-4xl sm:text-5xl text-white font-bold tracking-tight mb-4">Reconhecimento</h2>
      <p class="text-neutral-400 text-lg">Atestados validados de quem respira diariamente a exclusividade da Modular Montagens Pensadas em Cuiabá.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 w-full max-w-6xl">
      {testimonials.map((testimonial) => (
        <div class="flex flex-col h-full bg-black border border-neutral-800 rounded-2xl p-8 hover:border-[#C5A03F]/30 hover:-translate-y-2 transition-all duration-300 shadow-xl group">
          
          <div class="flex items-center justify-between mb-6">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 rounded-full bg-neutral-900 border border-neutral-700 flex items-center justify-center text-white font-bold text-xl font-heading shadow-inner">
                {testimonial.initial}
              </div>
              <div class="flex flex-col">
                <span class="text-white font-bold tracking-tight text-sm">{testimonial.name}</span>
                <span class="text-neutral-500 text-xs font-semibold">{testimonial.time}</span>
              </div>
            </div>
            <!-- Google "G" small icon -->
            <div class="w-8 h-8 rounded-full bg-neutral-900 border border-neutral-800 flex items-center justify-center opacity-80">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 488 512" class="w-4 h-4 fill-white"><path d="M488 261.8C488 403.3 391.1 504 248 504 110.8 504 0 393.2 0 256S110.8 8 248 8c66.8 0 123 24.5 166.3 64.9l-67.5 64.9C258.5 52.6 94.3 116.6 94.3 256c0 86.5 69.1 156.6 153.7 156.6 98.2 0 135-70.4 140.8-106.9H248v-85.3h236.1c2.3 12.7 3.9 24.9 3.9 41.4z"/></svg>
            </div>
          </div>

          <div class="flex gap-1 mb-4 text-[#C5A03F]">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 flex-shrink-0" viewBox="0 0 20 20" fill="currentColor">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>
          
          <p class="text-neutral-300 text-base leading-relaxed flex-grow opacity-90">
            "{testimonial.text}"
          </p>
          
        </div>
      ))}
    </div>
    
  </div>
</section>
