                    </svg>
                  ))}
                </div>
                <span class="text-neutral-500 text-xs font-semibold">{t.time}</span>
              </div>

              <!-- Review Text -->
              <p class="text-neutral-300 text-sm leading-relaxed opacity-95">
                "{t.text}"
              </p>
            </div>

            <!-- Owner Response Reply Box -->
            {t.reply && (
              <div class="mt-5 p-4 bg-neutral-900/30 border-l border-[#C5A03F]/40 rounded-r-xl rounded-bl-xl text-xs space-y-1.5">
                <div class="flex items-center justify-between">
                  <span class="text-white font-bold">{t.reply.author}</span>
                  <span class="text-neutral-500 text-[10px] font-semibold">{t.reply.time}</span>
                </div>
                <span class="text-neutral-500 block text-[10px] uppercase font-bold tracking-widest">{t.reply.role}</span>
                <p class="text-neutral-300 leading-relaxed italic mt-1">
                  "{t.reply.text}"
                </p>
