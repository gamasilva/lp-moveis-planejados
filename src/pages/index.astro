---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Founder from '../components/Founder.astro';
import QualityGuarantee from '../components/QualityGuarantee.astro';
import Gallery from '../components/Gallery.astro';
import SocialProof from '../components/SocialProof.astro';
import LeadForm from '../components/LeadForm.astro';
import Location from '../components/Location.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Móveis Planejados em Cuiabá e VG | Montagem Rápida e Limpa" 
  description="Atrase na obra nunca mais! Execução de projetos de móveis sob medida com plano de corte computadorizado. Montagem rápida em Cuiabá, Várzea Grande e região."
>
  <main>
    <Hero />
    <Gallery />
    <About />
    <Founder />
    <QualityGuarantee />
    <SocialProof />
    <LeadForm />
    <Location />
  </main>
  <Footer />
</BaseLayout>
