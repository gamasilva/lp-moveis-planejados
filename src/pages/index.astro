---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Founder from '../components/Founder.astro';
import QualityGuarantee from '../components/QualityGuarantee.astro';
import Gallery from '../components/Gallery.astro';
import SocialProof from '../components/SocialProof.astro';
import LeadForm from '../components/LeadForm.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Modular Montagens Pensadas | Móveis e Montagens em Cuiabá" 
  description="Transformamos seu ambiente com projetos exclusivos e montagens impecáveis. A Modular Montagens Pensadas traz materiais nobres e precisão milimétrica para você."
>
  <main>
    <Hero />
    <Gallery />
    <About />
    <Founder />
    <QualityGuarantee />
    <SocialProof />
    <LeadForm />
  </main>
  <Footer />
</BaseLayout>
